{
  "name": "antigravity-auto-accept",
  "displayName": "Antigravity Auto-Accept",
  "description": "Auto-accept agent commands, terminal commands, and file edits in Antigravity IDE — fully hands-free operation",
  "version": "3.0.2",
  "publisher": "nextcortex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nextcortex/antigravity-monitor.git"
  },
  "homepage": "https://github.com/nextcortex/antigravity-monitor",
  "engines": {
    "vscode": "^1.74.0"
  },
  "icon": "assets/icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "antigravity",
    "gemini",
    "auto-accept",
    "auto-approve",
    "agent"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:antigravityAutoAccept.configPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aga.toggleAutoAccept",
        "title": "Antigravity Auto-Accept: Toggle",
        "icon": "$(check-all)"
      },
      {
        "command": "aga.showLogs",
        "title": "Antigravity Auto-Accept: Show Logs",
        "icon": "$(output)"
      }
    ],
    "keybindings": [
      {
        "command": "aga.toggleAutoAccept",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": [
      {
        "title": "Antigravity Auto-Accept",
        "properties": {
          "aga.autoAccept": {
            "type": "boolean",
            "default": false,
            "description": "Auto-accept agent commands and file edits"
          },
          "aga.autoAcceptInterval": {
            "type": "number",
            "default": 800,
            "minimum": 200,
            "maximum": 5000,
            "description": "Auto-accept check interval in ms"
          },
          "aga.autoAcceptCommands": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "antigravity.agent.acceptAgentStep",
              "antigravity.terminalCommand.accept",
              "antigravity.command.accept",
              "antigravity.acceptCompletion",
              "antigravity.prioritized.agentAcceptAllInFile",
              "antigravity.prioritized.agentAcceptFocusedHunk",
              "antigravity.prioritized.supercompleteAccept",
              "antigravity.prioritized.terminalSuggestion.accept"
            ],
            "description": "VS Code commands to fire each auto-accept tick"
          },
          "aga.autoAcceptSettings": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "antigravity.agent.terminal.autoExecutionPolicy",
              "antigravity.agent.terminal.confirmCommands",
              "antigravity.agent.terminal.allowedCommands",
              "antigravity.terminal.autoRun",
              "cortex.agent.autoRun",
              "geminicodeassist.agentYoloMode",
              "gemini.cli.yoloMode"
            ],
            "description": "Setting keys to auto-enable when auto-accept is ON"
          },
          "aga.autoAcceptKeywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "accept",
              "run",
              "retry",
              "apply",
              "execute",
              "confirm",
              "allow once",
              "allow"
            ],
            "description": "Button text keywords to auto-click (accept list)"
          },
          "aga.autoAcceptRejectKeywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "skip",
              "reject",
              "cancel",
              "close",
              "refine",
              "always",
              "aga:"
            ],
            "description": "Button text keywords to never auto-click (reject list)"
          },
          "aga.debugMode": {
            "type": "boolean",
            "default": false,
            "description": "Enable debug logging"
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "antigravityAutoAccept-explorer",
          "title": "Antigravity Auto-Accept",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "antigravityAutoAccept-explorer": [
        {
          "type": "webview",
          "id": "antigravityAutoAccept.configPanel",
          "name": "Configuration",
          "icon": "assets/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}